mqtt:
  enabled: true
  broker-url: tcp://localhost:1883

jwt:
  # 로컬 개발 전용 시크릿 — 운영 환경에서는 반드시 JWT_SECRET 환경변수 사용
  secret: SmartOfficeLocalDevSecretKeyMustBe32CharsOrMore!!

spring:
#  Local-H2 Settings
#  datasource:
#    url: jdbc:h2:mem:smartoffice;MODE=MySQL;NON_KEYWORDS=VALUE;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
#    driver-class-name: org.h2.Driver
#    username: sa
#    password:
#
#  h2:
#    console:
#      enabled: true
#      path: /h2-console

#  Local-Mysql Settings
  datasource:
    url: jdbc:mysql://localhost:3306/smartoffice
    driver-class-name: com.mysql.cj.jdbc.Driver
    username: root
    password: 1234

  jpa:
    hibernate:
      ddl-auto: validate

  data:
    redis:
      host: localhost
      port: 6379

logging:
  level:
    com.grown.smartoffice: DEBUG
    org.hibernate.SQL: DEBUG
    org.springframework.security: DEBUG