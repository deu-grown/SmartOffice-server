mqtt:
  enabled: true
  broker-url: tcp://localhost:1883

jwt:
  # 로컬 개발 전용 시크릿 — HS256 최소 32자 이상 임의 문자열로 설정
  secret: <YOUR_LOCAL_JWT_SECRET_MIN_32_CHARS>

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/smartoffice
    driver-class-name: com.mysql.cj.jdbc.Driver
    username: root
    password: <YOUR_LOCAL_DB_PASSWORD>

  jpa:
    hibernate:
      ddl-auto: validate

  data:
    redis:
      host: localhost
      port: 6379

logging:
  level:
    com.grown.smartoffice: DEBUG
    org.hibernate.SQL: DEBUG
    org.springframework.security: DEBUG
